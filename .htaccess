## REWRITE DEFAULTS

RewriteEngine On
ErrorDocument 404 /index.php
# RewriteBase /
# Detectar si se accede al directorio sin la barra final
#
#RewriteCond %{REQUEST_FILENAME} !-f
#RewriteCond %{REQUEST_URI} !/$
#RewriteRule ^(.*)$ /$1/ [L,R=301]
#RewriteRule ^([^/]+)/([^/]+)/([^/]+)/([^/]+)/?$ /$1/$2/$3/ [R=301,L]
#RewriteCond %{HTTP_HOST} ^novaquim\.com [NC]
#RewriteRule ^(.*)$ https://www.novaquim.com/$1 [R=301,L]
RewriteRule ^productos/(.*)/(.*)/ categoria.php?tipo=$1&descripcion=$2 [L]
RewriteRule ^productos/(.*)/ producto.php?&producto=$1 [L]


#RewriteCond %{REQUEST_FILENAME} !-f
#RewriteCond %{REQUEST_FILENAME} !-d
#RewriteRule ^.*$ / [L,R=301]